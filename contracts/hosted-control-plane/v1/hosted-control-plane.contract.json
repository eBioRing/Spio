{
  "schema_version": 1,
  "contract_name": "spio hosted control plane",
  "contract_version": "v1",
  "base_path": "/api/styio-hosted/v1",
  "workspace_path_parameter": "workspace_id",
  "operations": [
    {
      "id": "openWorkspace",
      "method": "POST",
      "path": "/workspaces/open",
      "request_shape": "OpenWorkspaceRequest",
      "success_shape": "HostedProjectGraphEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "projectGraph",
      "method": "GET",
      "path": "/workspaces/{workspace_id}/project-graph",
      "request_shape": "NoRequestBody",
      "success_shape": "HostedProjectGraphEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "toolInstall",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/tool/install",
      "request_shape": "ToolInstallRequest",
      "success_shape": "ToolCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "toolUse",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/tool/use",
      "request_shape": "ToolVersionRequest",
      "success_shape": "ToolCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "toolPin",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/tool/pin",
      "request_shape": "ToolVersionRequest",
      "success_shape": "ToolCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "toolClearPin",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/tool/clear-pin",
      "request_shape": "EmptyObject",
      "success_shape": "ToolCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "fetchDependencies",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/dependencies/fetch",
      "request_shape": "DependencyFetchRequest",
      "success_shape": "DependencyCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "vendorDependencies",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/dependencies/vendor",
      "request_shape": "DependencyVendorRequest",
      "success_shape": "DependencyCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "runWorkflow",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/execution/run",
      "request_shape": "ExecutionWorkflowRequest",
      "success_shape": "ExecutionCommandEnvelope",
      "failure_shape": "ExecutionCommandEnvelope"
    },
    {
      "id": "buildWorkflow",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/execution/build",
      "request_shape": "ExecutionWorkflowRequest",
      "success_shape": "ExecutionCommandEnvelope",
      "failure_shape": "ExecutionCommandEnvelope"

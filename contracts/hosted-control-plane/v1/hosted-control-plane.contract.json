    {
      "id": "testWorkflow",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/execution/test",
      "request_shape": "ExecutionWorkflowRequest",
      "success_shape": "ExecutionCommandEnvelope",
      "failure_shape": "ExecutionCommandEnvelope"
    },
    {
      "id": "packProject",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/deployment/pack",
      "request_shape": "DeploymentRequest",
      "success_shape": "DeploymentCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "preparePublish",
      "method": "POST",
      "path": "/workspaces/{workspace_id}/deployment/preflight",
      "request_shape": "DeploymentRequest",
      "success_shape": "DeploymentCommandEnvelope",
      "failure_shape": "HostedCommandFailureEnvelope"
    },
    {
      "id": "publishToRegistry",

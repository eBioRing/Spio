{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pafio.dev/contracts/registry-v2/v1/signed-namespace-targets.schema.json",
  "title": "pafio Registry V2 Signed Namespace Targets Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signed",
    "signatures"
  ],
  "properties": {
    "signed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "spec_version",
        "version",
        "expires",
        "namespace",
        "packages"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "targets"
        },
        "spec_version": {
          "type": "string",
          "const": "1"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "expires": {
          "type": "string",
          "format": "date-time"
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "packages": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "index_path",
              "latest_version",
              "releases"
            ],
            "properties": {
              "index_path": {
                "type": "string",
                "pattern": "^index/.+\\.jsonl$"
              },
              "latest_version": {
                "type": "string",
                "minLength": 1
              },
              "releases": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "release_revision",
                    "index_record_sha256",
                    "source_artifact_sha256",
                    "source_artifact_path",
                    "binary_artifact_count"
                  ],
                  "properties": {
                    "release_revision": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "index_record_sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "source_artifact_sha256": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{64}$"
                    },
                    "source_artifact_path": {
                      "type": "string",
                      "pattern": "^artifacts/source/"
                    },
                    "binary_artifact_count": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "signatures": {
      "$ref": "#/$defs/signatures"
    }
  },
  "$defs": {
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "keyid",
          "sig"
        ],
        "properties": {
          "keyid": {
            "type": "string",
            "minLength": 1
          },
          "sig": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
